rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: /users/{userId}/goals
    // Fields: id, title, description, progress, status, createdAt
    //
    // Collection: /users/{userId}/tasks
    // Fields: id, goalId, title, status, priority, estimatedTime, createdAt, completedAt
    //
    // Collection: /users/{userId}/memory
    // Fields: id, content, url, summary, category, createdAt
    //
    // Collection: /users/{userId}/dailyLogs
    // Fields: id, date, achievements, feedback, mood, createdAt
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return (isAuthenticated() && request.auth.uid == userId) || userId == 'hua-default';
    }

    function isValidGoal(data) {
      return data.keys().hasAll(['id', 'title', 'status']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.status in ['active', 'completed', 'archived'];
    }

    function isValidTask(data) {
      return data.keys().hasAll(['id', 'title', 'status', 'priority']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.status in ['todo', 'done'] &&
             data.priority in ['urgent', 'easy', 'normal'];
    }

    function isValidMemoryItem(data) {
      return data.keys().hasAll(['id', 'content', 'category']) &&
             data.content is string && data.content.size() > 0 && data.content.size() < 5000 &&
             data.category in ['daily', 'learning', 'project', 'other'];
    }

    function isValidDailyLog(data) {
      return data.keys().hasAll(['id', 'date', 'feedback']) &&
             data.date is string && data.feedback is string && data.feedback.size() < 2000;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "doratwotw@gmail.com" && request.auth.token.email_verified == true));
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();

      match /goals/{goalId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidGoal(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /tasks/{taskId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidTask(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /memory/{memoryId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidMemoryItem(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /dailyLogs/{logId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidDailyLog(request.resource.data);
        allow delete: if isOwner(userId);
      }

      match /chat/{messageId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.role in ['user', 'model'];
        allow delete: if isOwner(userId);
      }
    }
  }
}
